{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/AletheiaResearch/mnemosyne/schemas/canonical-v1.json",
  "title": "Mnemosyne Canonical Record",
  "type": "object",
  "required": [
    "record_id",
    "origin",
    "grouping",
    "model",
    "turns",
    "usage"
  ],
  "properties": {
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "origin": {
      "type": "string",
      "minLength": 1
    },
    "grouping": {
      "type": "string",
      "minLength": 1
    },
    "model": {
      "type": "string",
      "minLength": 1
    },
    "branch": {
      "type": "string"
    },
    "started_at": {
      "type": "string"
    },
    "ended_at": {
      "type": "string"
    },
    "working_dir": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "turns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "role"
        ],
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "user",
              "assistant"
            ]
          },
          "timestamp": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "reasoning": {
            "type": "string"
          },
          "tool_calls": {
            "type": "array"
          },
          "attachments": {
            "type": "array"
          }
        }
      }
    },
    "usage": {
      "type": "object",
      "required": [
        "user_turns",
        "assistant_turns",
        "tool_calls",
        "input_tokens",
        "output_tokens"
      ],
      "properties": {
        "user_turns": {
          "type": "integer"
        },
        "assistant_turns": {
          "type": "integer"
        },
        "tool_calls": {
          "type": "integer"
        },
        "input_tokens": {
          "type": "integer"
        },
        "output_tokens": {
          "type": "integer"
        }
      }
    },
    "_mnemosyne": {
      "type": "object"
    }
  }
}
