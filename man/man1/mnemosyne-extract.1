.nh
.TH "MNEMOSYNE" "1" "Jan 1970" "Mnemosyne" "Mnemosyne Manual"

.SH NAME
mnemosyne-extract - Extract local records into canonical JSONL


.SH SYNOPSIS
\fBmnemosyne extract [flags]\fP


.SH DESCRIPTION
Extract local records into canonical JSONL


.SH OPTIONS
\fB--attach-images\fP[=false]
	keep inline image attachments in isolate-mode output (has no effect without --isolate)

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for extract

.PP
\fB--include-all\fP[=false]
	ignore grouping exclusions and default scope to 'all'

.PP
\fB--isolate\fP[=false]
	also emit redacted copies of each native session file into [output]/isolate/[format]/

.PP
\fB--no-reasoning\fP[=false]
	omit reasoning traces from assistant turns

.PP
\fB--output\fP=""
	path for the canonical JSONL export

.PP
\fB--scope\fP=""
	source scope to extract, or 'all' (defaults to 'all' when --include-all is set)

.PP
\fB--verify-secrets\fP[=false]
	live-verify matched provider secrets against their issuing API (network access required)


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--config\fP=""
	path to the settings file

.PP
\fB--verbose\fP[=false]
	enable debug logging


.SH SEE ALSO
\fBmnemosyne(1)\fP
